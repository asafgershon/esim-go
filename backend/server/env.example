# Server Configuration
PORT=4000
NODE_ENV=development

# Supabase Configuration (REQUIRED - Get these from your Supabase project)
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# eSIM Go API Configuration (REQUIRED)
ESIM_GO_API_KEY=your-esim-go-api-key-here
ESIM_GO_BASE_URL=https://api.esim-go.com/v2.5
ESIM_GO_WEBHOOK_SECRET=
ESIM_GO_MODE=mock

# Maya API Configuration (Optional)
MAYA_API_KEY=
MAYA_API_SECRET=
MAYA_BASE_URL=https://api.maya.net/connectivity/v1

# Redis Configuration (Local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=mypassword

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
CHECKOUT_JWT_SECRET=secret-string

# Email Configuration
EMAIL_MODE=mock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_EMAIL_DOMAIN=hiiloworld.com
SES_FROM_EMAIL=
SES_CONFIGURATION_SET=

# EasyCard Payment Configuration
EASYCARD_API_KEY=
EASYCARD_IDENTITY_URL=https://identity.e-c.co.il
EASYCARD_API_URL=https://ecng-transactions.azurewebsites.net
EASYCARD_MERCHANT_URL=https://ecng-merchant.azurewebsites.net
EASYCARD_TERMINAL_ID=
EASYCARD_WEBHOOK_SECRET=
EASYCARD_MODE=test
EASYCARD_ENVIRONMENT=development

# URLs
DASHBOARD_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

